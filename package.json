{
  "name": "sapphirus-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Governed, local-authority AI workspace for Windows.",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter @sapphirus/desktop-ui dev",
    "build": "pnpm contracts:check:typescript && pnpm --filter @sapphirus/desktop-ui build",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "contracts:generate:cross-language": "pnpm --filter @sapphirus/contracts generate",
    "contracts:check:typescript": "pnpm --filter @sapphirus/contracts check:typescript",
    "contracts:verify:typescript": "pnpm --filter @sapphirus/contracts verify:typescript",
    "contracts:verify:cross-language": "pnpm --filter @sapphirus/contracts verify:cross-language",
    "contracts:test": "pnpm --filter @sapphirus/contracts test",
    "bmad:foundation:verify": "pnpm --filter @sapphirus/bmad-foundation run verify",
    "secrets:check": "node --test tools/check-secrets.test.mjs && node tools/check-secrets.mjs",
    "release:test": "node --test tools/release-metadata.test.mjs tools/release-sbom.test.mjs tools/release-attestation-predicate.test.mjs",
    "release:metadata": "node tools/resolve-release-metadata.mjs",
    "release:sbom": "node tools/generate-release-sbom.mjs",
    "vault:test": "node --test tools/tests/closed-manifest.test.mjs",
    "vault:check": "node tools/verify-reference-vault.mjs",
    "rust:fmt": "cargo fmt --all --check",
    "rust:clippy": "cargo clippy --workspace --all-targets --all-features --locked -- -D warnings",
    "rust:test": "cargo test --workspace --all-features --locked",
    "desktop:dev": "pnpm exec tauri dev --config crates/desktop-app/tauri.conf.json",
    "desktop:dev:deterministic": "pnpm exec tauri dev --config crates/desktop-app/tauri.conf.json --features deterministic-help",
    "desktop:build": "pnpm exec tauri build --config crates/desktop-app/tauri.conf.json --features deterministic-help",
    "verify:boundaries": "node tools/check-boundaries.mjs",
    "toolchain:check": "node tools/check-toolchain.mjs",
    "verify:source": "pnpm toolchain:check && pnpm bmad:foundation:verify && pnpm contracts:verify:typescript && pnpm secrets:check && pnpm release:test && pnpm typecheck && pnpm lint && pnpm test && pnpm verify:boundaries && pnpm build",
    "verify": "pnpm verify:source",
    "verify:deferred-full": "pnpm contracts:verify:cross-language && pnpm secrets:check && pnpm typecheck && pnpm lint && pnpm test && pnpm verify:boundaries && pnpm rust:fmt && pnpm rust:clippy && pnpm rust:test && pnpm build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "typescript": "7.0.2"
  }
}
