        "environment",
        "identity",
        "imagePullIdentity",
        "modelDeployment",
        "modelUser",
        "openAi",
        "privateDnsZoneGroups",
        "registry",
        "signingKey",
        "signingRole",
        "sqlDatabase",
        "sqlServer",
        "vault"
      ]
    },
    "acrPull": {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.ContainerRegistry/registries', variables('registryName'))]",
      "name": "[guid(resourceId('Microsoft.ContainerRegistry/registries', variables('registryName')), resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-pull-id', parameters('namePrefix'))), variables('roleIds').acrPull)]",
      "properties": {
        "principalId": "[reference('imagePullIdentity').principalId]",
