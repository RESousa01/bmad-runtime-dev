      "properties": {
        "addressSpace": {
          "addressPrefixes": [
            "10.42.0.0/16"
          ]
        },
        "subnets": [
          {
            "name": "container-apps",
            "properties": {
              "addressPrefix": "[variables('subnets').containerApps]",
              "delegations": [
                {
