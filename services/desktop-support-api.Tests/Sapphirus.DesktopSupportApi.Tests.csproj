<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
    <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="10.0.10" />
    <PackageReference Include="xunit.v3" Version="3.2.2" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../desktop-support-api/Sapphirus.DesktopSupportApi.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="../../packages/contracts/fixtures/valid/model-context-consent.json"
             Link="ContractFixtures/model-context-consent.json"
             CopyToOutputDirectory="PreserveNewest" />
    <Content Include="../../packages/contracts/fixtures/valid/model-access-receipt.json"
             Link="ContractFixtures/model-access-receipt.json"
             CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
