{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sapphirus.dev/v1/approved-execution-spec.schema.json",
  "title": "sapphirus.approved-execution-spec.v1",
  "$comment": "Immutable D3 Windows patch authority. Consumption state is held only by SpecConsumptionRecord.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "specId",
    "deliveryModel",
    "authorityRef",
    "ownerScopeRef",
    "projectId",
    "runId",
    "proposalId",
    "proposalHash",
    "candidateId",
    "candidateHash",
    "approvalId",
    "approvalDecisionHash",
    "policyVersion",
    "policyHash",
    "workspaceTargetHash",
    "mutableInputSetHash",
    "executorAudience",
    "issuedAt",
    "expiresAt",
    "singleUseNonceHash",
    "specHash"
  ],
  "properties": {
    "schemaVersion": { "const": "sapphirus.approved-execution-spec.v1" },
    "specId": { "$ref": "./common.schema.json#/$defs/ContractId" },
    "deliveryModel": { "const": "windows_local" },
    "authorityRef": { "$ref": "./common.schema.json#/$defs/DesktopLocalStoreAuthorityRef" },
    "ownerScopeRef": { "$ref": "./common.schema.json#/$defs/ContractId" },
    "projectId": { "$ref": "./common.schema.json#/$defs/ContractId" },
    "runId": { "$ref": "./common.schema.json#/$defs/ContractId" },
    "proposalId": { "$ref": "./common.schema.json#/$defs/ContractId" },
    "proposalHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
    "candidateId": { "$ref": "./common.schema.json#/$defs/ContractId" },
    "candidateHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
    "approvalId": { "$ref": "./common.schema.json#/$defs/ContractId" },
    "approvalDecisionHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
    "policyVersion": { "type": "string", "minLength": 1, "maxLength": 128 },
    "policyHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
    "workspaceTargetHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
    "mutableInputSetHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
    "executorAudience": { "$ref": "./common.schema.json#/$defs/NativePatchEngineAudience" },
    "issuedAt": { "$ref": "./common.schema.json#/$defs/UtcInstant" },
    "expiresAt": { "$ref": "./common.schema.json#/$defs/UtcInstant" },
    "singleUseNonceHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
    "specHash": { "$ref": "./common.schema.json#/$defs/Sha256" }
  }
}
