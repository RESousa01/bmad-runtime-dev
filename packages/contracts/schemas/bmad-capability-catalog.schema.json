{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.sapphirus.dev/v1/bmad-capability-catalog.schema.json",
  "title": "sapphirus.bmad-capability-catalog.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packageVersionId",
    "descriptorHash",
    "packageSourceHash",
    "installedSkills",
    "helpActionGraph",
    "dependencyAvailability",
    "agentRoster",
    "catalogHash"
  ],
  "properties": {
    "schemaVersion": { "const": "sapphirus.bmad-capability-catalog.v1" },
    "packageVersionId": { "$ref": "./common.schema.json#/$defs/ContractId" },
    "descriptorHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
    "packageSourceHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
    "installedSkills": {
      "type": "array",
      "maxItems": 4096,
      "items": { "$ref": "#/$defs/InstalledSkillRecord" }
    },
    "helpActionGraph": { "$ref": "#/$defs/BmadHelpActionGraph" },
    "dependencyAvailability": {
      "type": "array",
      "maxItems": 4096,
      "items": { "$ref": "#/$defs/BmadDependencyAvailability" }
    },
    "agentRoster": { "$ref": "#/$defs/BmadAgentRoster" },
    "catalogHash": { "$ref": "./common.schema.json#/$defs/Sha256" }
  },
  "$defs": {
    "BmadCapabilityKey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageVersionId",
        "moduleCode",
        "skillName",
        "normalizedAction"
      ],
      "properties": {
        "packageVersionId": { "$ref": "./common.schema.json#/$defs/ContractId" },
        "moduleCode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "skillName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "normalizedAction": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 128,
              "pattern": "^[a-z][a-z0-9_-]*$"
            },
            { "type": "null" }
          ]
        }
      }
    },
    "InstalledSkillRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageVersionId",
        "moduleCode",
        "skillName",
        "actionCardinality",
        "capabilityKeys",
        "sourceEntrypointHash",
        "resourceSetHash",
        "skillDescriptorHash",
        "executionProfileHash",
        "instructionProjectionHash",
        "distributionProfile",
        "installProfile",
        "entrypointKind",
        "validationProfile",
        "installationObservationHash"
      ],
      "properties": {
        "packageVersionId": { "$ref": "./common.schema.json#/$defs/ContractId" },
        "moduleCode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "skillName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "actionCardinality": { "enum": ["single_action", "multi_action"] },
        "capabilityKeys": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/BmadCapabilityKey" }
        },
        "sourceEntrypointHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "resourceSetHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "skillDescriptorHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "executionProfileHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "instructionProjectionHash": {
          "oneOf": [
            { "$ref": "./common.schema.json#/$defs/Sha256" },
            { "type": "null" }
          ]
        },
        "distributionProfile": {
          "$ref": "./bmad-package-descriptor.schema.json#/$defs/BmadDistributionProfile"
        },
        "installProfile": {
          "$ref": "./bmad-package-descriptor.schema.json#/$defs/BmadInstallProfile"
        },
        "entrypointKind": {
          "enum": [
            "direct",
            "inline",
            "step_jit",
            "script_rendered",
            "compatibility_shim"
          ]
        },
        "validationProfile": {
          "enum": [
            "MethodOfficialSkillV6",
            "MethodStepWorkflowV6",
            "BuilderOutcomeSkillV2",
            "BuilderAgentV2Stateless",
            "MethodCliInstalledV6",
            "StandaloneBuilderSetupV2"
          ]
        },
        "installationObservationHash": { "$ref": "./common.schema.json#/$defs/Sha256" }
      }
    },
    "BmadHelpActionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capabilityKey",
        "sourceMemberHash",
        "sourceRowHash",
        "sourceOrdinal",
        "rawRow",
        "normalized"
      ],
      "properties": {
        "capabilityKey": { "$ref": "#/$defs/BmadCapabilityKey" },
        "sourceMemberHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "sourceRowHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "sourceOrdinal": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "rawRow": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "module",
            "skill",
            "display-name",
            "menu-code",
            "description",
            "action",
            "args",
            "phase",
            "preceded-by",
            "followed-by",
            "required",
            "output-location",
            "outputs"
          ],
          "properties": {
            "module": { "type": "string", "maxLength": 1024 },
            "skill": { "type": "string", "maxLength": 1024 },
            "display-name": { "type": "string", "maxLength": 4096 },
            "menu-code": { "type": "string", "maxLength": 128 },
            "description": { "type": "string", "maxLength": 16384 },
            "action": { "type": "string", "maxLength": 1024 },
            "args": { "type": "string", "maxLength": 4096 },
            "phase": { "type": "string", "maxLength": 4096 },
            "preceded-by": { "type": "string", "maxLength": 8192 },
            "followed-by": { "type": "string", "maxLength": 8192 },
            "required": { "type": "string", "maxLength": 64 },
            "output-location": { "type": "string", "maxLength": 8192 },
            "outputs": { "type": "string", "maxLength": 8192 }
          }
        },
        "normalized": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "phase",
            "precededBy",
            "followedBy",
            "required",
            "outputLocations",
            "outputs"
          ],
          "properties": {
            "phase": {
              "oneOf": [
                { "type": "string", "minLength": 1, "maxLength": 256 },
                { "type": "null" }
              ]
            },
            "precededBy": {
              "type": "array",
              "maxItems": 64,
              "items": { "$ref": "#/$defs/BmadCapabilityKey" }
            },
            "followedBy": {
              "type": "array",
              "maxItems": 64,
              "items": { "$ref": "#/$defs/BmadCapabilityKey" }
            },
            "required": { "type": "boolean" },
            "outputLocations": {
              "type": "array",
              "maxItems": 64,
              "items": { "type": "string", "minLength": 1, "maxLength": 2048 }
            },
            "outputs": {
              "type": "array",
              "maxItems": 64,
              "items": { "type": "string", "minLength": 1, "maxLength": 2048 }
            }
          }
        }
      }
    },
    "BmadHelpActionGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageVersionId", "actions", "graphHash"],
      "properties": {
        "packageVersionId": { "$ref": "./common.schema.json#/$defs/ContractId" },
        "actions": {
          "type": "array",
          "maxItems": 4096,
          "items": { "$ref": "#/$defs/BmadHelpActionRecord" }
        },
        "graphHash": { "$ref": "./common.schema.json#/$defs/Sha256" }
      }
    },
    "BmadDependencyAvailability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capabilityKey", "availability", "evidenceHash"],
      "properties": {
        "capabilityKey": { "$ref": "#/$defs/BmadCapabilityKey" },
        "availability": {
          "enum": [
            "available_external_dependency",
            "unavailable_missing_skill",
            "unavailable_missing_module",
            "unavailable_profile_mismatch"
          ]
        },
        "evidenceHash": { "$ref": "./common.schema.json#/$defs/Sha256" }
      }
    },
    "BmadAgentRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "moduleCode",
        "agentCode",
        "name",
        "title",
        "icon",
        "team",
        "description",
        "moduleSourceHash",
        "personaSourceHash",
        "customizationSourceHash",
        "personaCustomizationGraphHash",
        "menuItems",
        "menuGraphHash",
        "agentRecordHash"
      ],
      "properties": {
        "moduleCode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "agentCode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 256 },
        "title": { "type": "string", "minLength": 1, "maxLength": 256 },
        "icon": { "type": "string", "minLength": 1, "maxLength": 64 },
        "team": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 256 },
            { "type": "null" }
          ]
        },
        "description": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "moduleSourceHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "personaSourceHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "customizationSourceHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "personaCustomizationGraphHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "menuItems": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/BmadAgentMenuItem" }
        },
        "menuGraphHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "agentRecordHash": { "$ref": "./common.schema.json#/$defs/Sha256" }
      }
    },
    "BmadAgentRoster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packageVersionId", "agents", "rosterHash"],
      "properties": {
        "packageVersionId": { "$ref": "./common.schema.json#/$defs/ContractId" },
        "agents": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/BmadAgentRecord" }
        },
        "rosterHash": { "$ref": "./common.schema.json#/$defs/Sha256" }
      }
    },
    "BmadAgentMenuItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "menuCode",
        "displayName",
        "description",
        "sourceOrdinal",
        "sourceMenuItemHash",
        "target"
      ],
      "properties": {
        "menuCode": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "pattern": "^[A-Za-z0-9_-]+$"
        },
        "displayName": { "type": "string", "minLength": 1, "maxLength": 256 },
        "description": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "sourceOrdinal": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "sourceMenuItemHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "target": { "$ref": "#/$defs/BmadAgentMenuTarget" }
      }
    },
    "BmadAgentMenuTarget": {
      "oneOf": [
        { "$ref": "#/$defs/BmadAgentSkillTarget" },
        { "$ref": "#/$defs/BmadAgentPromptReferenceTarget" }
      ]
    },
    "BmadAgentSkillTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetKind", "sourceCustomizationGraphHash", "capabilityKey"],
      "properties": {
        "targetKind": { "const": "skill_target" },
        "sourceCustomizationGraphHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "capabilityKey": { "$ref": "#/$defs/BmadCapabilityKey" }
      }
    },
    "BmadAgentPromptReferenceTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetKind",
        "sourceCustomizationGraphHash",
        "sourceLocalMemberLabel",
        "sourceMemberHash",
        "availability"
      ],
      "properties": {
        "targetKind": { "const": "prompt_reference" },
        "sourceCustomizationGraphHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "sourceLocalMemberLabel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u202a-\\u202e\\u2066-\\u2069])(?:\\.|(?!/)(?![A-Za-z]:)(?!.*:)(?!.*(?:^|/)\\.\\.?(?:/|$))(?!.*\\\\).+)$"
        },
        "sourceMemberHash": { "$ref": "./common.schema.json#/$defs/Sha256" },
        "availability": { "const": "unavailable_source_prompt" }
      }
    }
  }
}
