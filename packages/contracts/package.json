{
  "name": "@sapphirus/contracts",
  "version": "0.1.0-beta.1",
  "private": true,
  "description": "Canonical Windows-local desktop wire contracts and conformance fixtures for Sapphirus.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "fixtures",
    "generated",
    "schemas",
    "schema-lock.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./generated/typescript/contracts.ts",
      "default": "./generated/typescript/runtime.mjs"
    },
    "./validation": {
      "types": "./generated/typescript/validation.d.mts",
      "default": "./generated/typescript/validation.mjs"
    },
    "./semantics": {
      "types": "./generated/typescript/semantic-validation.d.mts",
      "default": "./generated/typescript/semantic-validation.mjs"
    },
    "./schemas/*": "./schemas/*",
    "./fixtures/*": "./fixtures/*",
    "./schema-lock.json": "./schema-lock.json"
  },
  "scripts": {
    "generate": "node ./scripts/generate-all.mjs",
    "check": "node ./scripts/qualify-generators.mjs --check && node ./scripts/generate.mjs --check && node ./scripts/check-schemas.mjs && tsc --project ./tsconfig.json --noEmit && tsc --project ../../tests/generator-qualification/typescript/tsconfig.json --noEmit",
    "check:typescript": "node ./scripts/generate.mjs --check --typescript-only && node ./scripts/check-schemas.mjs && tsc --project ./tsconfig.json --noEmit && node ./scripts/check-typescript-bindings.mjs",
    "qualify:generators": "node ./scripts/qualify-generators.mjs --check && tsc --project ../../tests/generator-qualification/typescript/tsconfig.json --noEmit",
    "qualify:typescript": "tsc --project ../../tests/generator-qualification/typescript/tsconfig.json --noEmit",
    "lint": "node ./scripts/check-schemas.mjs",
    "test": "tsc --project ./tsconfig.json --noEmit && node ./scripts/run-tests.mjs",
    "typecheck": "tsc --project ./tsconfig.json --noEmit && node ./scripts/check-typescript-bindings.mjs",
    "verify": "node ./scripts/generate.mjs --check --typescript-only && node ./scripts/check-schemas.mjs && tsc --project ./tsconfig.json --noEmit && node ./scripts/check-typescript-bindings.mjs && node ./scripts/run-tests.mjs",
    "verify:typescript": "node ./scripts/generate.mjs --check --typescript-only && node ./scripts/check-schemas.mjs && tsc --project ./tsconfig.json --noEmit && node ./scripts/check-typescript-bindings.mjs && node ./scripts/run-tests.mjs",
    "verify:cross-language": "node ./scripts/qualify-generators.mjs --check && node ./scripts/generate.mjs --check && node ./scripts/check-schemas.mjs && tsc --project ./tsconfig.json --noEmit && tsc --project ../../tests/generator-qualification/typescript/tsconfig.json --noEmit && node ./scripts/check-generated-bindings.mjs && node ./scripts/run-tests.mjs --include-native"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "canonicalize": "3.0.0"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "json-schema-to-typescript": "15.0.4",
    "typescript": "7.0.2"
  },
  "sapphirusToolchain": {
    "jsonSchemaDraft": "2020-12",
    "typescriptCompiler": "typescript@7.0.2",
    "typescriptGenerator": "json-schema-to-typescript@15.0.4",
    "typescriptValidator": "ajv@8.20.0",
    "rustGenerator": "cargo-typify@0.6.1",
    "rustValidator": "jsonschema@0.44.1",
    "dotnetGenerator": "Corvus.Json.Cli@5.2.7",
    "dotnetRuntime": "Corvus.Text.Json@5.2.7"
  },
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.15.1"
  }
}
